# BP Tracker — build-time env (Vite inlines VITE_* at build).
# Copy to .env.local for local dev; set the same keys in the Render dashboard.

# Supabase project (shared BBF backend)
VITE_SUPABASE_URL=https://ihclbceghxpuawymlvgi.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Web Push — VAPID PUBLIC key only (safe to expose). Generate a keypair with:
#   npx web-push generate-vapid-keys
# Put the PUBLIC key here and the PRIVATE key in the edge-function secrets.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

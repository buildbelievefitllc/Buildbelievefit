      "min": 1,
      "max": 10,
      "description": "1 = No pain/discomfort, 10 = Severe pain"
    },
    "diagnosis_routing": {
      "high_pain": {
        "range": [7, 10],
        "action": "regress",
        "prescription_focus": [
          "prehab",
          "recovery",
          "breathing_and_meditation"
        ],
        "intensity_modifier": 0.5
      },
      "moderate_pain": {
        "range": [4, 6],
        "action": "maintain",
        "prescription_focus": [
          "mobility",
          "prehab"
        ],
        "intensity_modifier": 0.8
      },
      "low_pain": {
        "range": [1, 3],
        "action": "progress",
        "prescription_focus": [
          "strengthening",
          "mobility"
        ],
        "intensity_modifier": 1.1
      }
    }
  },

{
  "name": "bbf-vault",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Build Believe Fit · Vault SPA · Vite + React + TypeScript (Phase 4.1)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",

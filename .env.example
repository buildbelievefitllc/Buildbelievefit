# ─────────────────────────────────────────────────────────────────────────────
# Build Believe Fit — environment template.  Copy to `.env` and fill in.
# `.env` is gitignored; never commit real values. This template documents the
# variables this repo reads — not necessarily every legacy var.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core: Express/WS proxy (index.js) ────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=          # Supabase service-role key (server-side only — never ship to a client)
ANTHROPIC_API_KEY=
BBF_WS_TICKET_SECRET=          # signing secret for WS tickets
PORT=3000

# ── Admin gate (shared secret for X-BBF-Admin-Token on admin-gated edge fns) ──
BBF_COACH_AGENT_TOKEN=

# ── Calling Card caller (scripts/publish-calling-card.mjs) ───────────────────
SUPABASE_ANON_KEY=             # anon/publishable key — gateway apikey header for edge calls
# Reuses SUPABASE_URL + BBF_COACH_AGENT_TOKEN above.

# ── TikTok Content Posting API (bbf-tiktok-oauth / bbf-tiktok-publish) ────────
# Prefer injecting these into Supabase Vault (see the function README); env is a
# fallback. Edge functions receive SUPABASE_SERVICE_ROLE_KEY auto-injected by the
# platform — only set it here if you run functions locally.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=https://<project-ref>.supabase.co/functions/v1/bbf-tiktok-oauth  # optional; must match the console (exact)
# TIKTOK_TOKEN=                # optional static access-token fallback (legacy/manual)
